		{
			"name": "2. Invoice Operations",
			"item": [
				{
					"name": "Send Invoice to Zoho",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invoiceData\": {\n    \"invoiceNumber\": \"TEST-NEW-001\",\n    \"accountNumber\": \"ACC-001\",\n    \"client\": {\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"phone\": \"+254712345678\"\n    },\n    \"facility\": {\n      \"name\": \"Test Facility\"\n    },\n    \"unit\": {\n      \"name\": \"Unit 1A\"\n    },\n    \"currency\": {\n      \"code\": \"KES\"\n    },\n    \"items\": [\n      {\n        \"description\": \"Monthly Rent\",\n        \"quantity\": 1,\n        \"unitPrice\": 50000\n      }\n    ],\n    \"totalAmount\": 50000,\n    \"amountPaid\": 0,\n    \"issueDate\": \"2025-10-27T00:00:00.000Z\",\n    \"dueDate\": \"2025-11-27T00:00:00.000Z\",\n    \"status\": \"Unpaid\"\n  },\n  \"options\": {\n    \"skipIfExists\": true,\n    \"recordPayment\": false,\n    \"markAsSent\": true\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/integrations/zoho/invoices/send",
							"host": ["{{base_url}}"],
							"path": ["api", "integrations", "zoho", "invoices", "send"]
						},
						"description": "Create and send a single invoice to Zoho Books."
					},
					"response": []
				},
				{
					"name": "Bulk Send Invoices",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invoices\": [\n    {\n      \"invoiceNumber\": \"BULK-TEST-001\",\n      \"accountNumber\": \"ACC-001\",\n      \"client\": {\n        \"firstName\": \"Jane\",\n        \"lastName\": \"Smith\"\n      },\n      \"facility\": {\n        \"name\": \"Test Facility\"\n      },\n      \"unit\": {\n        \"name\": \"Unit 1\"\n      },\n      \"currency\": {\n        \"code\": \"KES\"\n      },\n      \"items\": [\n        {\n          \"description\": \"Rent\",\n          \"quantity\": 1,\n          \"unitPrice\": 10000\n        }\n      ],\n      \"totalAmount\": 10000,\n      \"issueDate\": \"2025-10-27T00:00:00.000Z\",\n      \"dueDate\": \"2025-11-27T00:00:00.000Z\",\n      \"status\": \"Unpaid\"\n    },\n    {\n      \"invoiceNumber\": \"BULK-TEST-002\",\n      \"accountNumber\": \"ACC-002\",\n      \"client\": {\n        \"firstName\": \"Bob\",\n        \"lastName\": \"Johnson\"\n      },\n      \"facility\": {\n        \"name\": \"Test Facility\"\n      },\n      \"unit\": {\n        \"name\": \"Unit 2\"\n      },\n      \"currency\": {\n        \"code\": \"KES\"\n      },\n      \"items\": [\n        {\n          \"description\": \"Rent\",\n          \"quantity\": 1,\n          \"unitPrice\": 15000\n        }\n      ],\n      \"totalAmount\": 15000,\n      \"issueDate\": \"2025-10-27T00:00:00.000Z\",\n      \"dueDate\": \"2025-11-27T00:00:00.000Z\",\n      \"status\": \"Unpaid\"\n    }\n  ],\n  \"options\": {\n    \"skipIfExists\": true,\n    \"recordPayment\": false,\n    \"markAsSent\": true\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/integrations/zoho/invoices/bulk-send",
							"host": ["{{base_url}}"],
							"path": ["api", "integrations", "zoho", "invoices", "bulk-send"]
						},
						"description": "Send multiple invoices to Zoho Books in one operation."
					},
					"response": []
				},
