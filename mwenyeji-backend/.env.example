# MongoDB — a dedicated database for Mwenyeji, independent of PayServe's
# payserve_property / payserve_movein databases. Any Atlas cluster works;
# just point this at a fresh database name, e.g. ".../mwenyeji?..."
MONGODB_URI=mongodb+srv://mwenyeji:Kenya2030@mwenyeji.notoxni.mongodb.net/mwenyeji?retryWrites=true&w=majority

# JWT signing secret — generate a long random string, keep it secret.
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=3050
NODE_ENV=production

# CORS — comma-separated list of allowed origins.
ALLOWED_ORIGINS=https://mwenyeji.com,https://www.mwenyeji.com,http://localhost:3001

# Google Cloud Storage (unit image uploads) — reused from the existing setup.
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# M-Pesa (Safaricom Daraja) — STK push for viewing fees, rent/reservation
# payments, and listing boosts. MPESA_CALLBACK_URL must be a public HTTPS
# URL (Safaricom cannot reach localhost) — use ngrok or your deployed URL
# while testing, pointing at POST /api/move_in/payments/mpesa/callback.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_TRANSACTION_TYPE=CustomerBuyGoodsOnline
MPESA_CALLBACK_URL=
